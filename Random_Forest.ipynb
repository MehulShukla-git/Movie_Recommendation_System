            "[nltk_data] Downloading package wordnet to /root/nltk_data...\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "from sklearn.feature_extraction.text import TfidfVectorizer\n",
        "from scipy.sparse import hstack\n",
        "\n",
        "tfidf = TfidfVectorizer(max_features=5000, stop_words='english')\n",
        "\n",
        "tfidf_matrix = tfidf.fit_transform(df['tags'])\n",
        "\n",
        "# Convert numeric\n",
        "df['vote_average'] = pd.to_numeric(df['vote_average'], errors='coerce').fillna(0)\n",
        "df['popularity'] = pd.to_numeric(df['popularity'], errors='coerce').fillna(0)\n",
        "\n",
        "X_num = df[['vote_average','popularity']].values\n",
        "\n",
        "# Combine\n",
        "X = hstack((tfidf_matrix, X_num)).tocsr()"
      ],
      "metadata": {
        "id": "5DkChoLYtPnv"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "df['target'] = df['vote_average'].apply(lambda x: 1 if x >= 6 else 0)\n",
        "\n",
        "y = df['target']"
      ],
      "metadata": {
        "id": "Inr2vv15tPlA"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "from sklearn.model_selection import train_test_split\n",
        "\n",
        "X_dense = X.toarray()\n",
        "\n",
        "X_train, X_test, y_train, y_test = train_test_split(\n",
        "    X_dense, y, test_size=0.2, random_state=42\n",
        ")"
      ],
      "metadata": {
        "id": "jVjFQsAStPit"
      },
